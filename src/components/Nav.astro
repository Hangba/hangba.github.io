---
import siteConfig, { type Link } from "../site.config";
import Hamburger from "./Hamburger.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import SiteIdentity from "./SiteIdentity.astro";
import NavLinks from "./NavLinks.astro";
import PostTools from "./PostTools.astro";
import { withBase } from "../utils/helpers";
const { activePage } = Astro.props;
---

<header id="site-header">
  <nav class="font-light w-full site-nav">
    <a href={withBase("/")} class="nav-logo-link"><SiteIdentity /></a>
    <div class="desktop-links hidden sm:flex sm:gap-8">
      {(<NavLinks activePage={activePage} links={siteConfig.headerNavLinks} />)}
    </div>
    <Hamburger />
  </nav>
  <div
    id="mobile-links"
    class="font-light animated h-0 m-0 opacity-0 top-0 w-full"
  >
    <span class="close-menu" aria-label="Close menu">&times;</span>
    <NavLinks
      activePage={activePage}
      links={siteConfig.headerNavLinks}
      isMobileLink={true}
    />
  </div>
  <PostTools />
</header>
<script>
  declare global {
    interface Window {
      _navScrollBound?: boolean;
    }
  }

  function setMobileMenuExpanded(isExpanded: boolean) {
    document.documentElement.dataset.mobileMenuExpanded = isExpanded ? "true" : "false";
  }

  function closeMobileMenu(mobile = document.querySelector("#mobile-links")) {
    if (!(mobile instanceof HTMLElement)) {
      setMobileMenuExpanded(false);
      return;
    }

    if (
      !mobile.classList.contains("expanded") &&
      document.documentElement.dataset.mobileMenuExpanded !== "true"
    ) {
      setMobileMenuExpanded(false);
      return;
    }

    mobile.classList.add("slideOutUp", "expanded");
    mobile.classList.remove("slideInDown");
    setMobileMenuExpanded(false);
  }

  function bindNav() {
    const ham = document.querySelector("#hamburger-menu");
    const close = document.querySelector(".close-menu");
    const mobile = document.querySelector("#mobile-links");
    const homeLinks = document.querySelectorAll(".nav-logo-link");
    if (!ham || !close || !mobile) return;
    setMobileMenuExpanded(mobile.classList.contains("expanded"));
    homeLinks.forEach((link) => {
      if (link instanceof HTMLAnchorElement && link.dataset.boundHome !== "1") {
        link.dataset.boundHome = "1";
        link.addEventListener("click", () => {
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, left: 0, behavior: "auto" });
          });
        });
      }
    });
    if ((ham as HTMLElement).dataset.boundNav !== "1") {
      (ham as HTMLElement).dataset.boundNav = "1";
      ham.addEventListener("click", () => {
        mobile.classList.remove("slideOutUp");
        mobile.classList.add("expanded", "slideInDown");
        setMobileMenuExpanded(true);
      });
    }
    if ((close as HTMLElement).dataset.boundNav !== "1") {
      (close as HTMLElement).dataset.boundNav = "1";
      close.addEventListener("click", () => {
        closeMobileMenu(mobile);
      });
    }
  }
  bindNav();
  document.addEventListener("astro:page-load", bindNav);

  function bindScroll() {
    // Use a global flag to avoid duplicate listeners on Astro soft-routing
    if (!window._navScrollBound) {
      window._navScrollBound = true;
      let isScrolled = false;
      
      const onScroll = () => {
        const currentHeader = document.getElementById('site-header');
        if (!currentHeader) return;
        if (!isScrolled && window.scrollY > 90) {
          isScrolled = true;
          currentHeader.classList.add('nav-scrolled');
          closeMobileMenu();
        } else if (isScrolled && window.scrollY < 50) {
          isScrolled = false;
          currentHeader.classList.remove('nav-scrolled');
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }
  bindScroll();
document.addEventListener("astro:page-load", bindScroll);
</script>

<style>
  /* Anchor the height so shrinking the inner nav NEVER changes document height causing scroll loops */
  :global(#site-header) {
    height: 76px; /* Fixed robust height */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  :global(#site-header .site-nav) {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    height: 56px; /* Explicitly fixed height to stop vertical jittering */
    transition: max-width 0.4s cubic-bezier(0.25, 1, 0.5, 1),
                background-color 0.4s ease,
                box-shadow 0.4s ease,
                border-color 0.4s ease,
                padding 0.4s ease,
                border-radius 0.4s ease;
    transform-origin: center;
    max-width: 1200px;
    width: 100%; /* ALWAYS 100% so we animate only max-width to shrink */
    margin: 0 auto;
    position: relative;
    box-sizing: border-box;
    border-radius: 9999px;
    padding: 0.55rem 1.25rem;
    font-size: 0.82rem;
    white-space: nowrap;
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(#site-header .nav-logo-link),
  :global(#site-header .nav-logo-link .sigmar-ff) {
    white-space: nowrap;
  }
  
  :global(#site-header .desktop-links) {
    transition:
      max-width 0.42s cubic-bezier(0.25, 1, 0.5, 1) 0.06s,
      opacity 0.28s ease,
      margin 0.42s cubic-bezier(0.25, 1, 0.5, 1),
      padding 0.42s cubic-bezier(0.25, 1, 0.5, 1);
    transform-origin: center;
    max-width: 500px;
    opacity: 1;
    overflow: hidden;
    white-space: nowrap;
  }

  :global(#site-header.nav-scrolled .desktop-links) {
    transition:
      opacity 0.22s ease,
      max-width 0.42s cubic-bezier(0.25, 1, 0.5, 1) 0.05s,
      margin 0.42s cubic-bezier(0.25, 1, 0.5, 1),
      padding 0.42s cubic-bezier(0.25, 1, 0.5, 1);
    max-width: 0 !important;
    opacity: 0 !important;
    margin-left: 0 !important;
    padding: 0 !important;
    pointer-events: none;
  }

  :global(#site-header.nav-scrolled .site-nav) {
    /* Set exactly wide enough for "Logo+HangbaSteve\'s Blog+MenuIcon" */
    max-width: 280px;
    margin: 0 auto;
    padding: 0 1rem; 
    gap: 0.75rem;
    justify-content: center !important; 
    box-shadow:
      inset 0 0 0.5px 1px hsla(0, 0%, 100%, 0.075),
      0 0 0 1px hsla(0, 0%, 0%, 0.05),
      0 0.3px 0.4px hsla(0, 0%, 0%, 0.02),
      0 0.9px 1.5px hsla(0, 0%, 0%, 0.045),
      0 3.5px 6px hsla(0, 0%, 0%, 0.09);
    border-radius: 9999px;
    border-color: rgba(255,255,255,0.08);
    background-color: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
  }
  
  :global(#site-header.nav-scrolled) {
    /* Anchor header structurally */
    padding: 0;
  }

  @media (orientation: portrait) {
    #mobile-links.expanded {
      align-items: stretch;
      background:
        linear-gradient(145deg, rgba(17, 20, 30, 0.86), rgba(8, 10, 16, 0.92));
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.12) inset,
        0 24px 42px -24px rgba(0, 0, 0, 0.7);
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      justify-content: flex-start;
      position: fixed;
      z-index: 30;
      opacity: 1;
      padding: 0.85rem 0.95rem 0.95rem;
      width: min(19rem, calc(100vw - 1rem));
      max-height: min(72svh, 31rem);
      overflow: auto;
      right: 0.5rem;
      top: 0.5rem;
      height: auto !important;
      min-height: 0;
      border-radius: 1rem;
    }

    #mobile-links.expanded .close-menu {
      align-self: flex-end;
      line-height: 1;
      margin: 0 0 0.2rem;
      cursor: pointer;
      user-select: none;
      font-size: 1.6rem;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.95);
    }

    :global(#mobile-links.expanded .nav-link) {
      width: 100%;
      text-align: right;
      padding: 0.45rem 0.2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      text-decoration: none;
    }

    :global(#mobile-links.expanded .nav-link:last-child) {
      border-bottom: 0;
    }

    html.light #mobile-links.expanded,
    html[data-post-theme="paper"] #mobile-links.expanded {
      background:
        linear-gradient(145deg, rgba(236, 224, 196, 0.95), rgba(220, 204, 170, 0.95));
      border-color: rgba(70, 50, 20, 0.22);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.55) inset,
        0 24px 42px -24px rgba(40, 25, 0, 0.32);
    }

    html.light #mobile-links.expanded .close-menu,
    html[data-post-theme="paper"] #mobile-links.expanded .close-menu {
      color: #1a1a1a;
    }

    html.light :global(#mobile-links.expanded .nav-link),
    html[data-post-theme="paper"] :global(#mobile-links.expanded .nav-link) {
      border-bottom-color: rgba(70, 50, 20, 0.15);
    }

    /* Keep home mobile menu aligned with the dark nav capsule style */
    html[data-page="home"] #mobile-links.expanded {
      background:
        linear-gradient(145deg, rgba(17, 20, 30, 0.86), rgba(8, 10, 16, 0.92));
      border-color: rgba(255, 255, 255, 0.16);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.12) inset,
        0 24px 42px -24px rgba(0, 0, 0, 0.7);
    }

    html[data-page="home"] #mobile-links.expanded .close-menu {
      color: rgba(255, 255, 255, 0.95);
    }

    html[data-page="home"] :global(#mobile-links.expanded .nav-link) {
      border-bottom-color: rgba(255, 255, 255, 0.1);
    }
  }

  @media (min-width: 640px) {
    :global(#site-header .site-nav) {
      font-size: 1rem;
      gap: 2rem;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
  }
</style>
