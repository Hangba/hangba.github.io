---
import SiteIdentity from "./SiteIdentity.astro";
const currentYear = new Date().getFullYear();
---

<footer class="kanit-light text-xs sm:text-sm mt-12 w-full max-w-4xl mx-auto px-4 pb-8 flex flex-col items-center border-t border-gray-800">
  <div class="flex flex-row items-center justify-center gap-8 py-8 w-full">
    <!-- GitHub Icon Link -->
    <a href="https://github.com/Hangba" target="_blank" title="GitHub" class="footer-icon text-gray-400 hover:text-white transition-colors">
      <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"></path>
      </svg>
    </a>

    <!-- Email Icon Link -->
    <a href="mailto:hangbamaybe@gmail.com" title="Email" class="footer-icon text-gray-400 hover:text-white transition-colors">
      <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current" aria-hidden="true">
        <path d="M20 4H4C2.9 4 2.01 4.9 2.01 6L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
      </svg>
    </a>
  </div>

  <div class="flex flex-col items-center justify-center min-w-full gap-2 footer-copy">
    <span class="tracking-widest text-xs uppercase opacity-80">Stay tuned!</span>
    <span class="footer-copyright">&copy; {currentYear} <strong>HangbaSteve</strong>. All rights reserved.</span>
  </div>
</footer>

<style>
  .footer-copy {
    color: color-mix(in srgb, var(--planet-accent, #e2d1c3) 75%, #8a8a8a);
    transition: color 600ms ease;
  }
  .footer-copyright strong {
    font-weight: 500;
    color: var(--planet-accent, #e2d1c3);
    letter-spacing: 0.02em;
    transition: color 600ms ease;
  }
  .footer-icon:hover {
    color: var(--planet-accent, #e2d1c3) !important;
  }

  :global(html[data-post-theme="paper"]) .footer-copy {
    color: rgba(70, 50, 20, 0.72);
  }
  :global(html[data-post-theme="paper"]) .footer-copyright strong {
    color: #8b5a20;
  }
  :global(html[data-post-theme="paper"]) .footer-icon {
    color: rgba(70, 50, 20, 0.7);
  }
  :global(html[data-post-theme="paper"]) .footer-icon:hover {
    color: #8b5a20 !important;
  }

  :global(html[data-post-theme="texture"]) .footer-copy {
    color: rgba(255, 255, 255, 0.72);
  }
  :global(html[data-post-theme="texture"]) .footer-copyright strong {
    color: #ffffff;
  }
  :global(html[data-post-theme="texture"]) .footer-icon {
    color: rgba(255, 255, 255, 0.72);
  }
  :global(html[data-post-theme="texture"]) .footer-icon:hover {
    color: #ffffff !important;
  }
</style>
