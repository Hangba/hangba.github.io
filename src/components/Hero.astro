---
import siteConfig from "../site.config";
import { withBase } from "../utils/helpers";
import { getTodayPlanet } from "../data/planets";
const planet = getTodayPlanet();
---

<section class="hero" data-reveal-root>
    {
        siteConfig.hero?.eyebrowText && (
            <span class="hero-eyebrow" data-reveal style="--reveal-delay:0ms">
                {siteConfig.hero?.eyebrowText}
            </span>
        )
    }
    <h1 class="hero-title" data-reveal style="--reveal-delay:80ms">
        {siteConfig.hero?.title}
    </h1>
    <p class="hero-sub" data-reveal style="--reveal-delay:240ms">
        {siteConfig.hero?.text}
    </p>
    <div class="hero-actions" data-reveal style="--reveal-delay:380ms">
        <a class="hero-cta" href={withBase("/blog")}>
            <span>Blog</span>
            <span aria-hidden="true">→</span>
        </a>
        <a class="hero-link" href="#recent-stories">↓ scroll</a>
    </div>
    <div class="planet-cycler" data-reveal style="--reveal-delay:520ms">
        <span class="planet-cycler-label">
            <span class="planet-cycler-dot" aria-hidden="true"></span>
            当前:<strong id="planet-cycler-name">{planet.name}</strong>
        </span>
        <button
            type="button"
            id="planet-cycler-btn"
            class="planet-cycler-btn"
        >
            换一颗 →
        </button>
    </div>
</section>

<script>
    import { planets } from "../data/planets";

    function bindCycler() {
        const btn = document.getElementById(
            "planet-cycler-btn"
        ) as HTMLButtonElement | null;
        const nameEl = document.getElementById("planet-cycler-name");
        const stage = document.getElementById("planet-stage");
        if (!btn || !nameEl || !stage) return;
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";

        let idx = 0;
        try {
            const current = JSON.parse(stage.dataset.planet || "{}");
            const found = planets.findIndex((p) => p.id === current.id);
            if (found >= 0) idx = found;
        } catch {
            /* fall back to 0 */
        }

        btn.addEventListener("click", () => {
            idx = (idx + 1) % planets.length;
            const next = planets[idx];
            const fn = (
                window as unknown as { __switchPlanet?: (p: typeof next) => void }
            ).__switchPlanet;
            if (fn) fn(next);
            nameEl.textContent = next.name;
        });
    }

    bindCycler();
    document.addEventListener("astro:page-load", bindCycler);
</script>

<style>
    .hero {
        position: relative;
        z-index: 3;
        min-height: 100vh;
        padding: 1vh 6vw 8vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        gap: 1.25rem;
        max-width: 1280px;
        margin: 0 auto;
        text-align: center;
    }

    .hero-eyebrow {
        display: inline-block;
        width: fit-content;
        font-size: 0.75rem;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        padding: 0.4rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(12px);
        color: var(--planet-accent, #e2d1c3);
    }

    .hero-title {
        font-size: clamp(3rem, 9vw, 8.5rem);
        line-height: 0.95;
        letter-spacing: -0.02em;
        font-weight: 300;
        max-width: 18ch;
        margin: 0;
        color: #f5f1ea;
        text-shadow: 0 4px 40px rgba(0, 0, 0, 0.35);
    }

    .hero-sub {
        max-width: 36ch;
        font-size: clamp(1rem, 1.4vw, 1.25rem);
        line-height: 1.6;
        color: rgba(245, 241, 234, 0.72);
        margin: 0;
        letter-spacing: 0.04em;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .hero-cta {
        display: inline-flex;
        gap: 0.6rem;
        align-items: center;
        padding: 0.85rem 1.6rem;
        border-radius: 999px;
        background: var(--planet-accent, #e2d1c3);
        color: #0a0a0a;
        font-size: 0.95rem;
        letter-spacing: 0.08em;
        text-decoration: none;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }
    .hero-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(226, 209, 195, 0.25);
    }

    .hero-link {
        font-size: 0.8rem;
        letter-spacing: 0.4em;
        opacity: 0.5;
        text-decoration: none;
        color: inherit;
    }
    .hero-link:hover {
        opacity: 1;
    }

    .planet-cycler {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.5rem 0.5rem 0.5rem 1rem;
        margin-top: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        color: rgba(245, 241, 234, 0.7);
    }
    .planet-cycler-label {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
    }
    .planet-cycler-label strong {
        font-weight: 400;
        color: var(--planet-accent, #e2d1c3);
    }
    .planet-cycler-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: var(--planet-accent, #e2d1c3);
        box-shadow: 0 0 10px var(--planet-accent, #e2d1c3);
        transition: background 600ms ease, box-shadow 600ms ease;
    }
    .planet-cycler-btn {
        cursor: pointer;
        border: 0;
        background: rgba(255, 255, 255, 0.08);
        color: inherit;
        font: inherit;
        letter-spacing: inherit;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        transition: background 200ms ease, color 200ms ease;
    }
    .planet-cycler-btn:hover {
        background: var(--planet-accent, #e2d1c3);
        color: #0a0a0a;
    }

    @media (max-width: 640px) {
        .hero {
            padding: 1vh 5vw 6vh;
            min-height: 100svh;
            justify-content: flex-start;
        }
        .hero-title {
            max-width: 14ch;
        }
    }
</style>
