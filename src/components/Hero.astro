---
import siteConfig from "../site.config";
import { getTodayPlanet } from "../data/planets";
const planet = getTodayPlanet();
const titleLines = siteConfig.hero?.titleLines;
---

<section class="hero" data-reveal-root>
    {
        titleLines && titleLines.length > 0 ? (
            <h1 class="hero-title hero-title--stacked" data-reveal style="--reveal-delay:80ms">
                {titleLines.map((line, i) => (
                    <>
                        {i > 0 && (
                            <span class="title-dash" aria-hidden="true">—</span>
                        )}
                        <span class="title-line">{line}</span>
                    </>
                ))}
            </h1>
        ) : (
            <h1 class="hero-title" data-reveal style="--reveal-delay:80ms">
                {siteConfig.hero?.title}
            </h1>
        )
    }
    <div class="hero-sub-frame" data-reveal style="--reveal-delay:240ms">
        <p class="hero-sub">
            {siteConfig.hero?.text}
        </p>
    </div>
</section>

<style>
    .hero {
        position: relative;
        z-index: 3;
        align-self: flex-end;
        min-height: 100vh;
        padding: 14vh 0 8vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-end;
        gap: 1.75rem;
        width: min(540px, 50vw);
        margin-left: auto;
        margin-right: 10vw;
        text-align: right;
    }

    .hero-title {
        font-size: clamp(3rem, 9vw, 8.5rem);
        line-height: 0.95;
        letter-spacing: -0.02em;
        font-weight: 300;
        margin: 0;
        color: #f5f1ea;
        text-shadow: 0 4px 40px rgba(0, 0, 0, 0.35);
    }

    .hero-title--stacked {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        line-height: 0.9;
        gap: 0.1em;
    }

    .title-line {
        display: block;
    }

    .title-dash {
        display: block;
        font-size: 0.55em;
        letter-spacing: 0.1em;
        opacity: 0.55;
        line-height: 1;
        margin: 0.15em 0;
    }

    .hero-sub-frame {
        position: relative;
        max-width: 38ch;
        margin-left: auto;
        padding: 1.6rem 0;
        text-align: left;
    }

    .hero-sub {
        font-family: var(--font-serif, "New Computer Modern Roman", serif);
        font-size: clamp(0.95rem, 1.15vw, 1.1rem);
        line-height: 1.75;
        color: rgba(245, 241, 234, 0.82);
        margin: 0;
        letter-spacing: 0.02em;
        font-style: italic;
    }

    @media (max-width: 768px) {
        .hero {
            width: 100%;
            margin-left: auto;
            margin-right: auto;
            align-items: center;
            text-align: center;
            padding: 36vh 5vw 6vh;
            min-height: 100svh;
            justify-content: flex-start;
        }
        .hero-title--stacked {
            align-items: center;
        }
        .hero-sub-frame {
            margin-left: auto;
            margin-right: auto;
        }
    }

    @media (min-width: 769px) {
        :global(html[data-page="home"]) .hero {
            align-self: flex-end !important;
            align-items: flex-end !important;
            text-align: right !important;
            margin-left: auto !important;
            margin-right: 10vw !important;
        }

        :global(html[data-page="home"]) .hero-title--stacked {
            align-items: flex-end !important;
        }
    }
</style>
