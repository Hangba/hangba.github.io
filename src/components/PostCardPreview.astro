---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";
import { formatReadingTime, withBase } from "../utils/helpers";

type Props = { post: CollectionEntry<"blogs"> };
const { post } = Astro.props;
const { title, pubDate, description, image } = post.data;
---

<a class="font-bold block w-full" href={withBase("/blog/" + post.id)}>
  <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 items-center sm:items-start">
    {
      image && image.url && (
        <>
          <Image
            class="self-start"
            src={image.url}
            alt={image.alt || ""}
            width={300}
            height={167}
          />
        </>
      )
    }
    <div class="flex flex-col w-full flex-1 items-center text-center">
      <h2 class="mb-1 text-center">{title}</h2>
      <div class="post-card-meta">
        <FormattedDate date={new Date(pubDate)} />
        <span aria-hidden="true">&middot;</span>
        <span>{formatReadingTime(post)}</span>
      </div>
      {
        description && (
          <p class="font-light text-base text-balance text-center">{description}</p>
        )
      }
    </div>
  </div>
</a>

<style>
  .post-card-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(245, 241, 234, 0.68);
    font-size: 0.88rem;
    font-weight: 300;
  }
</style>
