---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import PlanetStage from "../components/PlanetStage.astro";
import { getTodayPlanet } from "../data/planets";
import { withBase } from "../utils/helpers";
import siteConfig from "../site.config";

type LayoutProps = {
    pageTitle: string;
    activePage: string;
    pageKind?: string;
};
const { pageTitle, activePage, pageKind } = Astro.props as LayoutProps;

const planet = getTodayPlanet();

const pathname = Astro.url.pathname;
const dataPage = pageKind
    ? pageKind
    : activePage === "404"
      ? "404"
      : pathname === "/" || pathname === ""
        ? "home"
        : pathname.startsWith("/blog")
          ? "blog"
          : pathname.startsWith("/tags")
            ? "tags"
            : pathname.startsWith("/about")
              ? "about"
              : pathname.startsWith("/contact")
                ? "contact"
                : "home";

const textureStyle = planet.postTheme === "texture"
    ? `--planet-texture:url('${planet.colorMap}');`
    : "";
const themeStyle = `--planet-theme:${planet.themeColor};--planet-accent:${planet.accentColor};${textureStyle}`;
const showPlanet = dataPage === "home";
const postTheme = planet.postTheme ?? undefined;
---

<!doctype html>
<html
    lang="en"
    class="antialiased break-words dark"
    data-page={dataPage}
    data-planet-id={planet.id}
    data-post-theme={postTheme}
    style={themeStyle}
>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href={withBase(`/space-ahead-logo.png`)} />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href={withBase(`/sitemap-index.xml`)} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            href={withBase("/fonts/NCMM.woff2")}
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;700;900&family=Noto+Serif:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.25/dist/katex.min.css"
            crossorigin="anonymous"
        />
        {showPlanet && <link rel="preload" as="image" href={planet.colorMap} />}
        <link
            rel="alternate"
            type="application/rss+xml"
            title={siteConfig.title + " - RSS Feed"}
            href={new URL(withBase("/rss.xml"), Astro.site)}
        />
        <title>{pageTitle}</title>
        <ClientRouter />
    </head>
    <body>
        {showPlanet && <PlanetStage planet={planet} />}
        <main class="w-full mx-auto min-h-screen">
            <Nav activePage={activePage} />
            <slot />
            <Footer />
        </main>
        <script>
            import "../scripts/planet-stage";
        </script>
    </body>
</html>
