---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import PlanetStage from "../components/PlanetStage.astro";
import { getTodayPlanet, planets } from "../data/planets";
import { withBase } from "../utils/helpers";
import siteConfig from "../site.config";

type LayoutProps = {
    pageTitle: string;
    activePage: string;
    pageKind?: string;
};
const { pageTitle, activePage, pageKind } = Astro.props as LayoutProps;

const planet = getTodayPlanet();

const pathname = Astro.url.pathname;
const dataPage = pageKind
    ? pageKind
    : activePage === "404"
      ? "404"
      : pathname === "/" || pathname === ""
        ? "home"
        : pathname.startsWith("/blog")
          ? "blog"
          : pathname.startsWith("/tags")
            ? "tags"
            : pathname.startsWith("/about")
              ? "about"
                            : pathname.startsWith("/friends")
                  ? "friends"
                  : "home";

const textureStyle = planet.postTheme === "texture"
    ? `--planet-texture:url('${planet.colorMap}');`
    : "";
const themeStyle = `--planet-theme:${planet.themeColor};--planet-accent:${planet.accentColor};${textureStyle}`;
const showPlanet = dataPage === "home";
const postTheme = planet.postTheme ?? undefined;
const resolveStatusBarColor = (): string => {
    if (showPlanet) return planet.themeColor;
    if (planet.postTheme === "texture") return "#1c1e23";
    if (planet.postTheme === "paper") return planet.themeColor;
    return "#1b0f0d";
};
const statusBarColor = resolveStatusBarColor();
const htmlClass = [
    "antialiased",
    "break-words",
    "dark",
    showPlanet ? "home-planet-preload" : "",
]
    .filter(Boolean)
    .join(" ");
const planetThemeMap = Object.fromEntries(
    planets.map((p) => [
        p.id,
        {
            themeColor: p.themeColor,
            accentColor: p.accentColor,
            postTheme: p.postTheme,
            colorMap: p.colorMap,
        },
    ])
);
const lowResLogo = withBase("/logo-500p.png?v=2");
const highResLogo = withBase("/logo.png?v=2");
---

<!doctype html>
<html
    lang="en"
    class={htmlClass}
    data-page={dataPage}
    data-planet-id={planet.id}
    data-post-theme={postTheme}
    style={themeStyle}
>
    <head>
        <meta charset="utf-8" />
        <link
            id="site-favicon"
            rel="icon"
            type="image/png"
            sizes="500x500"
            href={lowResLogo}
            data-high-res-href={highResLogo}
        />
        <link rel="apple-touch-icon" href={lowResLogo} />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <meta name="theme-color" content={statusBarColor} />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href={withBase(`/sitemap-index.xml`)} />
        <link rel="preconnect" href="https://lalten.github.io" />
        <link
            rel="stylesheet"
            href="https://lalten.github.io/lmweb/style/latinmodern-roman.css"
            type="text/css"
            charset="utf-8"
        />
        <link
            rel="preload"
            href={withBase("/fonts/NCMM.woff2")}
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link rel="preconnect" href="https://fonts.loli.net" />
        <link rel="preconnect" href="https://gstatic.loli.net" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.loli.net/css2?family=Noto+Serif+SC:wght@300;400;700;900&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.25/dist/katex.min.css"
            crossorigin="anonymous"
        />
        {showPlanet && <link rel="preload" as="image" href={planet.colorMap} />}
        <link
            rel="alternate"
            type="application/rss+xml"
            title={siteConfig.title + " - RSS Feed"}
            href={new URL(withBase("/rss.xml"), Astro.site)}
        />
        <script is:inline define:vars={{ planetThemeMap }}>
            const applyPersistedPlanetTheme = () => {
                try {
                    const root = document.documentElement;
                    const id = sessionStorage.getItem("planet:currentId");
                    if (!id) return;
                    const config = planetThemeMap[id];
                    if (!config) return;

                    root.style.setProperty("--planet-theme", config.themeColor);
                    root.style.setProperty("--planet-accent", config.accentColor);
                    if (config.postTheme === "texture") {
                        root.style.setProperty(
                            "--planet-texture",
                            `url('${config.colorMap}')`
                        );
                    } else {
                        root.style.removeProperty("--planet-texture");
                    }

                    if (config.postTheme) {
                        root.dataset.postTheme = config.postTheme;
                    } else {
                        delete root.dataset.postTheme;
                    }
                    root.dataset.planetId = id;

                    const themeMeta = document.querySelector(
                        'meta[name="theme-color"]'
                    );
                    if (themeMeta) {
                        const page = root.dataset.page;
                        let barColor;
                        if (page === "home") {
                            barColor = config.themeColor;
                        } else if (config.postTheme === "texture") {
                            barColor = "#1c1e23";
                        } else if (config.postTheme === "paper") {
                            barColor = config.themeColor;
                        } else {
                            barColor = "#1b0f0d";
                        }
                        themeMeta.setAttribute("content", barColor);
                    }
                } catch {
                    /* ignore */
                }
            };

            applyPersistedPlanetTheme();
            document.addEventListener("astro:after-swap", applyPersistedPlanetTheme);
            document.addEventListener("astro:page-load", applyPersistedPlanetTheme);
        </script>
        <script is:inline>
            const enableNcmrWhenReady = () => {
                const root = document.documentElement;
                if (!root || !("fonts" in document)) return;

                const markReady = () => {
                    root.classList.add("ncmr-ready");
                };

                document.fonts
                    .load('400 1em "New Computer Modern Roman"')
                    .then(markReady)
                    .catch(() => {
                        /* keep Latin Modern fallback */
                    });
            };

            enableNcmrWhenReady();
            document.addEventListener("astro:after-swap", enableNcmrWhenReady);
            document.addEventListener("astro:page-load", enableNcmrWhenReady);
        </script>
        <title>{pageTitle}</title>
        <ClientRouter />
    </head>
    <body>
        {showPlanet && <PlanetStage planet={planet} />}
        <main class="w-full mx-auto min-h-screen">
            <Nav activePage={activePage} />
            <section id="page-content-shell">
                <slot />
            </section>
            <Footer />
        </main>
        <script>
            import "../scripts/planet-stage";
        </script>
        <script>
            const upgradeFavicon = () => {
                const favicon = document.querySelector<HTMLLinkElement>(
                    'link[rel="icon"][data-high-res-href]'
                );
                const highResHref = favicon?.dataset.highResHref;

                if (!favicon || !highResHref || favicon.href.endsWith(highResHref)) return;

                const highResIcon = new window.Image();
                highResIcon.decoding = "async";
                highResIcon.onload = () => {
                    favicon.href = highResHref;
                };
                highResIcon.src = highResHref;
            };

            const scheduleFaviconUpgrade = () => {
                if ("requestIdleCallback" in window) {
                    window.requestIdleCallback(upgradeFavicon, { timeout: 3000 });
                } else {
                    window.setTimeout(upgradeFavicon, 1500);
                }
            };

            if (document.readyState === "complete") {
                scheduleFaviconUpgrade();
            } else {
                window.addEventListener("load", scheduleFaviconUpgrade, { once: true });
            }
        </script>
    </body>
</html>
