---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import coverImage from "../assets/images/pixeltrue-space-discovery.svg";
---

<MainLayout activePage="about" pageTitle={siteConfig.title + " | About"}>
  <div class="page-content landing-content" data-reveal-root>
    <h1 class="sigmar-ff text-balance" data-reveal style="--reveal-delay:0ms">{siteConfig.about?.title}</h1>
    <div data-reveal style="--reveal-delay:120ms">
      <Image
        width={820}
        height={480}
        loading="eager"
        layout="constrained"
        class="rounded-4xl mb-8 mx-auto w-full max-w-[820px]"
        src={coverImage}
        alt="An Astronaut walking on a terrain"
      />
    </div>
    <p class="kanit-light text-left" data-reveal style="--reveal-delay:240ms">
      {siteConfig.about?.text}
    </p>
  </div>
</MainLayout>

<style>
  .landing-content {
    position: relative;
    z-index: 3;
  }
</style>
