---
import type { GetStaticPathsOptions, Page } from "astro";
import { type CollectionEntry, getCollection } from "astro:content";
import { Image } from "astro:assets";
import Pagination from "../../components/Pagination.astro";
import { formatReadingTime, sortItemsByDateDesc, withBase } from "../../utils/helpers";
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
import FormattedDate from "../../components/FormattedDate.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const blogs = (await getCollection("blogs", ({ data }) => !data.draft)).sort(
    sortItemsByDateDesc
  );
  return paginate(blogs, { pageSize: siteConfig.postsPerPage || 2 });
}

type Props = { page: Page<CollectionEntry<"blogs">> };

const { page } = Astro.props;
const allPosts = page.data;
const startIndex = (page.currentPage - 1) * (siteConfig.postsPerPage || 2);
---

<MainLayout activePage="blog" pageTitle={siteConfig.title + " | Blog Archive"}>
  <div class="page-content landing-content magazine-wrap" data-reveal-root>
    <div class="magazine-header" data-reveal style="--reveal-delay:0ms">
      <span class="magazine-kicker">The Journal &mdash; Vol. {page.currentPage}</span>
      <h1 class="magazine-masthead">Blog</h1>
      {
        siteConfig.blog?.description && (
          <p class="magazine-dek">{siteConfig.blog?.description}</p>
        )
      }
      <div class="magazine-rule" aria-hidden="true">
        <span class="magazine-rule-ornament">&#10070;</span>
      </div>
    </div>

    <div class="magazine-frame" data-reveal style="--reveal-delay:200ms">
      {
        allPosts.map((post, i) => {
          const index = startIndex + i + 1;
          const { title, pubDate, description, author, image } = post.data;
          return (
            <article class="magazine-entry">
              <div class="magazine-entry-meta">
                <span class="magazine-number">
                  {String(index).padStart(2, "0")}
                </span>
                <span class="magazine-date">
                  <FormattedDate date={new Date(pubDate)} />
                </span>
                {author && (
                  <span class="magazine-byline">by {author}</span>
                )}
                <span class="magazine-reading-time">{formatReadingTime(post)}</span>
              </div>
              <a class="magazine-link" href={withBase("/blog/" + post.id)}>
                <h2 class="magazine-title">{title}</h2>
                {description && (
                  <p class="magazine-excerpt">{description}</p>
                )}
                <span class="magazine-more">Read the piece &rarr;</span>
              </a>
              {image && image.url && (
                <a class="magazine-figure" href={withBase("/blog/" + post.id)}>
                  <Image
                    src={image.url}
                    alt={image.alt || ""}
                    width={640}
                    height={360}
                  />
                </a>
              )}
              {i < allPosts.length - 1 && (
                <div class="magazine-sep" aria-hidden="true">
                  <span>&middot; &middot; &middot;</span>
                </div>
              )}
            </article>
          );
        })
      }
    </div>

    <div data-reveal style="--reveal-delay:360ms">
      <Pagination page={page} class="mb-16 sm:mb-24" />
    </div>
  </div>
</MainLayout>

<style>
  .magazine-wrap {
    position: relative;
    z-index: 3;
  }

  .magazine-header {
    text-align: center;
    padding: 4rem 1rem 2rem;
    margin-bottom: 0;
  }

  .magazine-kicker {
    display: inline-block;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.72rem;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--planet-accent, #e2d1c3);
    margin-bottom: 1.25rem;
    opacity: 0.9;
  }

  .magazine-masthead {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-weight: 300;
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 1rem;
    color: #f5f1ea;
  }

  .magazine-dek {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-style: italic;
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 34ch;
    margin: 0 auto 1.75rem;
    color: rgba(245, 241, 234, 0.72);
    line-height: 1.6;
  }

  .magazine-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1rem auto 0;
    max-width: 20rem;
    color: var(--planet-accent, #e2d1c3);
    opacity: 0.65;
  }
  .magazine-rule::before,
  .magazine-rule::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
  }
  .magazine-rule-ornament {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
  }

  .magazine-frame {
    position: relative;
    max-width: 44rem;
    margin: 2rem auto 2.5rem;
    padding: 3rem clamp(1.5rem, 4vw, 3rem);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 2px;
    background: rgba(12, 12, 16, 0.38);
    backdrop-filter: blur(22px) saturate(140%);
    -webkit-backdrop-filter: blur(22px) saturate(140%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -28px rgba(0, 0, 0, 0.6);
    text-align: left;
  }

  .magazine-frame::before,
  .magazine-frame::after {
    content: "";
    position: absolute;
    left: clamp(1.5rem, 4vw, 3rem);
    right: clamp(1.5rem, 4vw, 3rem);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.18),
      transparent
    );
  }
  .magazine-frame::before {
    top: 0.75rem;
  }
  .magazine-frame::after {
    bottom: 0.75rem;
  }

  html.light .magazine-frame {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .magazine-entry {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .magazine-entry-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(245, 241, 234, 0.58);
  }

  .magazine-number {
    color: var(--planet-accent, #e2d1c3);
    font-weight: 500;
    letter-spacing: 0.1em;
    font-size: 0.84rem;
  }

  .magazine-date {
    letter-spacing: 0.25em;
  }

  .magazine-byline {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
  }

  .magazine-reading-time {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
  }

  .magazine-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .magazine-title {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 3.1vw, 2.25rem);
    line-height: 1.1;
    margin: 0.2rem 0 0.45rem;
    color: #f5f1ea;
    letter-spacing: -0.01em;
    transition: color 240ms ease;
  }

  .magazine-link:hover .magazine-title {
    color: var(--planet-accent, #e2d1c3);
  }

  .magazine-excerpt {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(245, 241, 234, 0.78);
    margin: 0 0 0.5rem;
  }

  .magazine-more {
    display: inline-block;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.68rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--planet-accent, #e2d1c3);
    opacity: 0.85;
    transition: opacity 240ms ease, transform 240ms ease;
  }

  .magazine-link:hover .magazine-more {
    opacity: 1;
    transform: translateX(4px);
  }

  .magazine-figure {
    display: block;
    margin-top: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .magazine-figure :global(img) {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(0.35) saturate(0.85) contrast(1.05);
    transition: filter 420ms ease, transform 420ms ease;
    border-radius: 0;
  }
  .magazine-figure:hover :global(img) {
    filter: grayscale(0) saturate(1) contrast(1);
    transform: scale(1.02);
  }

  .magazine-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 2.5rem 0 1rem;
    color: rgba(245, 241, 234, 0.35);
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    letter-spacing: 0.8em;
    font-size: 0.85rem;
  }

  /* Paper theme — Venus / Saturn / Jupiter: cream listing */
  :global(html[data-post-theme="paper"]) .magazine-kicker {
    color: #6b4a18;
    opacity: 1;
  }
  :global(html[data-post-theme="paper"]) .magazine-masthead {
    color: #1a120a;
  }
  :global(html[data-post-theme="paper"]) .magazine-dek {
    color: rgba(50, 35, 15, 0.78);
  }
  :global(html[data-post-theme="paper"]) .magazine-rule {
    color: #8b5a20;
    opacity: 0.8;
  }
  :global(html[data-post-theme="paper"]) .magazine-rule::before,
  :global(html[data-post-theme="paper"]) .magazine-rule::after {
    background: linear-gradient(to right, transparent, rgba(70,50,20,0.3), transparent);
  }
  :global(html[data-post-theme="paper"]) .magazine-frame {
    background: rgba(234, 221, 194, 0.9);
    border-color: rgba(70, 50, 20, 0.18);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 24px 48px -28px rgba(40, 25, 0, 0.25);
  }
  :global(html[data-post-theme="paper"]) .magazine-frame::before,
  :global(html[data-post-theme="paper"]) .magazine-frame::after {
    background: linear-gradient(to right, transparent, rgba(70,50,20,0.22), transparent);
  }
  :global(html[data-post-theme="paper"]) .magazine-entry-meta {
    color: rgba(70, 50, 20, 0.75);
  }
  :global(html[data-post-theme="paper"]) .magazine-number {
    color: #8b5a20;
  }
  :global(html[data-post-theme="paper"]) .magazine-title {
    color: #1a120a;
  }
  :global(html[data-post-theme="paper"]) .magazine-link:hover .magazine-title {
    color: #8b5a20;
  }
  :global(html[data-post-theme="paper"]) .magazine-excerpt {
    color: rgba(50, 35, 15, 0.82);
  }
  :global(html[data-post-theme="paper"]) .magazine-more {
    color: #8b5a20;
    opacity: 1;
  }
  :global(html[data-post-theme="paper"]) .magazine-figure {
    border-color: rgba(70, 50, 20, 0.2);
  }
  :global(html[data-post-theme="paper"]) .magazine-sep {
    color: rgba(70, 50, 20, 0.4);
  }

  /* Slate theme — Moon / Mercury: dark gray solid, white text on blur frame */
  :global(html[data-post-theme="texture"]) .magazine-kicker {
    color: rgba(255, 255, 255, 0.78);
    opacity: 1;
  }
  :global(html[data-post-theme="texture"]) .magazine-masthead {
    color: #ffffff;
  }
  :global(html[data-post-theme="texture"]) .magazine-dek {
    color: rgba(255, 255, 255, 0.78);
  }
  :global(html[data-post-theme="texture"]) .magazine-rule {
    color: rgba(255, 255, 255, 0.72);
    opacity: 1;
  }
  :global(html[data-post-theme="texture"]) .magazine-rule::before,
  :global(html[data-post-theme="texture"]) .magazine-rule::after {
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.35), transparent);
  }
  :global(html[data-post-theme="texture"]) .magazine-frame {
    background: rgba(18, 18, 24, 0.45);
    border-color: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(32px) saturate(125%);
    -webkit-backdrop-filter: blur(32px) saturate(125%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.1) inset,
      0 30px 56px -32px rgba(0, 0, 0, 0.85);
  }
  :global(html[data-post-theme="texture"]) .magazine-frame::before,
  :global(html[data-post-theme="texture"]) .magazine-frame::after {
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.28), transparent);
  }
  :global(html[data-post-theme="texture"]) .magazine-entry-meta {
    color: rgba(255, 255, 255, 0.65);
  }
  :global(html[data-post-theme="texture"]) .magazine-number {
    color: rgba(255, 255, 255, 0.95);
  }
  :global(html[data-post-theme="texture"]) .magazine-title {
    color: #ffffff;
  }
  :global(html[data-post-theme="texture"]) .magazine-link:hover .magazine-title {
    color: rgba(255, 255, 255, 0.82);
  }
  :global(html[data-post-theme="texture"]) .magazine-excerpt {
    color: rgba(255, 255, 255, 0.88);
  }
  :global(html[data-post-theme="texture"]) .magazine-more {
    color: rgba(255, 255, 255, 0.95);
    opacity: 1;
  }
  :global(html[data-post-theme="texture"]) .magazine-figure {
    border-color: rgba(255, 255, 255, 0.18);
  }
  :global(html[data-post-theme="texture"]) .magazine-sep {
    color: rgba(255, 255, 255, 0.4);
  }

  /* Mars style on non-home pages */
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-kicker {
    color: #f0a982;
    opacity: 1;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-masthead {
    color: #ffe6d5;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-dek {
    color: rgba(247, 229, 214, 0.82);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-rule {
    color: rgba(240, 169, 130, 0.88);
    opacity: 1;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-rule::before,
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-rule::after {
    background: linear-gradient(to right, transparent, rgba(240,169,130,0.35), transparent);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-frame {
    background: rgba(32, 16, 14, 0.5);
    border-color: rgba(240, 169, 130, 0.24);
    backdrop-filter: blur(28px) saturate(120%);
    -webkit-backdrop-filter: blur(28px) saturate(120%);
    box-shadow:
      0 1px 0 rgba(255, 240, 230, 0.08) inset,
      0 30px 56px -32px rgba(0, 0, 0, 0.8);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-frame::before,
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-frame::after {
    background: linear-gradient(to right, transparent, rgba(240,169,130,0.24), transparent);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-entry-meta {
    color: rgba(247, 229, 214, 0.68);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-number {
    color: #f0a982;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-title {
    color: #ffe6d5;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-link:hover .magazine-title {
    color: #ffd4bd;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-excerpt {
    color: rgba(247, 229, 214, 0.86);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-more {
    color: #f0a982;
    opacity: 1;
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-figure {
    border-color: rgba(240, 169, 130, 0.25);
  }
  :global(html.dark[data-planet-id="mars"]:not([data-page="home"])) .magazine-sep {
    color: rgba(240, 169, 130, 0.45);
  }

  /* Jupiter archive readability: deep-brown text */
  :global(html.dark[data-planet-id="jupiter"]) .magazine-kicker {
    color: #6b4a18;
    opacity: 1;
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-masthead {
    color: #1a120a;
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-dek {
    color: rgba(50, 35, 15, 0.82);
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-entry-meta {
    color: rgba(70, 50, 20, 0.78);
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-number,
  :global(html.dark[data-planet-id="jupiter"]) .magazine-more {
    color: #8b5a20;
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-title {
    color: #1a120a;
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-link:hover .magazine-title {
    color: #8b5a20;
  }
  :global(html.dark[data-planet-id="jupiter"]) .magazine-excerpt {
    color: rgba(50, 35, 15, 0.86);
  }

  @media (max-width: 640px) {
    .magazine-header {
      padding: 3rem 0.5rem 1.5rem;
    }
    .magazine-frame {
      padding: 2rem 1.25rem;
    }
    .magazine-entry-meta {
      gap: 0.65rem;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      flex-wrap: wrap;
    }
  }
</style>
