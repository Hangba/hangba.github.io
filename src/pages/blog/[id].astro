---
import "../../styles/global.css";
import { Image } from "astro:assets";
import {
  formatReadingTime,
  sortItemsByDateDesc,
  createSlugFromTitle,
  withBase,
} from "../../utils/helpers";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Button from "../../components/Button.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import ArrowLeft from "../../icons/ArrowLeft.astro";
import ArrowRight from "../../icons/ArrowRight.astro";
import siteConfig from "../../site.config";

export async function getStaticPaths() {
  const posts = (await getCollection("blogs", ({ data }) => !data.draft)).sort(
    sortItemsByDateDesc
  );
  const postCount = posts.length;
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: index + 1 !== postCount ? posts[index + 1] : null,
      nextPost: index !== 0 ? posts[index - 1] : null,
    },
  }));
}

type Props = {
  post: CollectionEntry<"blogs">;
  prevPost: CollectionEntry<"blogs">;
  nextPost: CollectionEntry<"blogs">;
};

const { post, prevPost, nextPost } = Astro.props;
const { title, pubDate, author, tags = [], image } = post.data;
const { Content, headings } = await render(post);
const tocItems = (headings ?? []).filter((h) => h.depth >= 2 && h.depth <= 3);
const dateLabel = new Date(pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<MainLayout activePage="blog" pageKind="blog-post" pageTitle={siteConfig.title + " | " + title}>
  <article class="page-content landing-content post-wrap" data-reveal-root>
    <div class="post-header">
      <span class="post-kicker" data-reveal style="--reveal-delay:0ms">
        The Journal &mdash; Dispatch
      </span>
      <h1 class="post-title" data-reveal style="--reveal-delay:80ms">{title}</h1>
      <div class="post-meta" data-reveal style="--reveal-delay:160ms">
        <span class="post-byline">
          by <em>{author}</em>
        </span>
        <span class="post-meta-dot" aria-hidden="true">&middot;</span>
        <time class="post-date">{dateLabel}</time>
        <span class="post-meta-dot" aria-hidden="true">&middot;</span>
        <span class="post-reading-time">{formatReadingTime(post)}</span>
      </div>
      <div class="post-rule" aria-hidden="true" data-reveal style="--reveal-delay:200ms">
        <span class="post-rule-ornament">&#10070;</span>
      </div>
    </div>

    {
      image && image.url && (
        <figure class="post-figure" data-reveal style="--reveal-delay:240ms">
          <Image src={image.url} alt={image.alt || ""} />
          {image.alt && <figcaption>{image.alt}</figcaption>}
        </figure>
      )
    }

    <div class="post-reading-shell" data-reveal style="--reveal-delay:320ms">
      <aside class="post-side post-side-left" aria-label="Search in article">
        <div class="post-side-panel">
          <p class="post-side-title">Signal Search</p>
          <label class="sr-only" for="post-search-input">Search this article</label>
          <input
            id="post-search-input"
            class="post-search-input"
            type="search"
            placeholder="Search this dispatch..."
            autocomplete="off"
          />
          <ul id="post-search-results" class="post-search-results" aria-live="polite">
            <li class="post-search-empty">Type to search inside this article</li>
          </ul>
        </div>
      </aside>

      <div class="blog-body-frame text-left">
        <div class="blog-body" id="post-body-content">
          <Content />
        </div>
      </div>

      <aside class="post-side post-side-right" aria-label="Article outline">
        <div class="post-side-panel">
          <p class="post-side-title">Structure</p>
          <nav id="post-outline" class="post-outline" aria-label="Table of contents">
            {
              tocItems.length > 0 ? (
                <ol>
                  {tocItems.map((item) => (
                    <li class:list={["outline-item", `depth-${item.depth}`]}>
                      <a href={`#${item.slug}`}>{item.text}</a>
                    </li>
                  ))}
                </ol>
              ) : (
                <p class="post-outline-empty">No section headings found.</p>
              )
            }
          </nav>
        </div>
      </aside>
    </div>

    {tags && tags.length > 0 && (
      <div class="post-tags" data-reveal style="--reveal-delay:400ms">
        <span class="post-tags-label">Filed under</span>
        {
          tags.map((tag) => (
            <Button
              class="px-4! m-1"
              href={withBase("/tags/" + createSlugFromTitle(tag))}
            >
              {tag}
            </Button>
          ))
        }
      </div>
    )}

    <div class="post-footer-rule" aria-hidden="true" data-reveal style="--reveal-delay:440ms">
      <span>&#10070;</span>
    </div>

    <nav class="post-nav" data-reveal style="--reveal-delay:480ms">
      <Button class="back-link" href={withBase("/blog")}>
        <ArrowLeft class="w-5 h-5 fill-current mr-4" /> Back to All Stories
      </Button>
      {
        (prevPost || nextPost) && nextPost && (
          <Button
            class="back-link text-balance"
            href={withBase("/blog/" + nextPost.id)}
          >
            Next Post: {nextPost.data.title}{" "}
            <ArrowRight class="w-5 h-5 fill-current ml-4" />
          </Button>
        )
      }
    </nav>
  </article>
</MainLayout>

<script is:inline>
  const initPostDesktopPanels = () => {
    const shell = document.querySelector(".post-reading-shell");
    if (!shell) return;

    const body = shell.querySelector("#post-body-content");
    const input = shell.querySelector("#post-search-input");
    const results = shell.querySelector("#post-search-results");
    const outline = shell.querySelector("#post-outline");

    if (!(body instanceof HTMLElement)) return;
    if (!(input instanceof HTMLInputElement)) return;
    if (!(results instanceof HTMLUListElement)) return;

    const searchTargets = Array.from(
      body.querySelectorAll("h2, h3, h4, p, li, blockquote")
    ).map((node, index) => {
      const el = node;
      const text = el.textContent?.trim() || "";
      if (!text) return null;
      if (!el.id) {
        const seed = text
          .toLowerCase()
          .replace(/[^a-z0-9\u4e00-\u9fa5\s-]/g, "")
          .trim()
          .replace(/\s+/g, "-")
          .slice(0, 40);
        el.id = `post-node-${seed || "section"}-${index}`;
      }
      return { el, text, id: el.id };
    }).filter(Boolean);

    const clearResults = (message) => {
      results.innerHTML = "";
      const li = document.createElement("li");
      li.className = "post-search-empty";
      li.textContent = message;
      results.appendChild(li);
    };

    const jumpToElement = (el) => {
      el.scrollIntoView({ behavior: "smooth", block: "start" });
      el.classList.add("post-search-hit");
      window.setTimeout(() => el.classList.remove("post-search-hit"), 1400);
    };

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      if (query.length < 2) {
        clearResults("Type at least 2 characters");
        return;
      }

      const matches = searchTargets
        .filter((item) => item.text.toLowerCase().includes(query))
        .slice(0, 8);

      if (matches.length === 0) {
        clearResults("No matching fragments in this article");
        return;
      }

      results.innerHTML = "";
      matches.forEach((item) => {
        const li = document.createElement("li");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "post-search-result-btn";
        btn.textContent = item.text;
        btn.addEventListener("click", () => jumpToElement(item.el));
        li.appendChild(btn);
        results.appendChild(li);
      });
    });

    if (outline instanceof HTMLElement) {
      const links = Array.from(outline.querySelectorAll("a[href^='#']"));
      if (links.length > 0 && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const id = entry.target.id;
              links.forEach((link) => {
                const active = link.getAttribute("href") === `#${id}`;
                link.classList.toggle("is-current", active);
              });
            });
          },
          { rootMargin: "-25% 0px -60% 0px", threshold: 0.01 }
        );

        links.forEach((link) => {
          const targetId = link.getAttribute("href")?.slice(1);
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (target) observer.observe(target);
        });
      }
    }
  };

  initPostDesktopPanels();
  document.addEventListener("astro:page-load", initPostDesktopPanels);
</script>

<style>
  .post-wrap {
    position: relative;
    z-index: 3;
    max-width: none !important;
    width: 100%;
  }

  .post-header {
    text-align: center;
    padding: 4rem 1rem 1.5rem;
  }

  .post-kicker {
    display: inline-block;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.72rem;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--planet-accent, #e2d1c3);
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .post-title {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-weight: 400;
    font-size: clamp(2.05rem, 4.6vw, 3.45rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 auto 1.25rem;
    max-width: 22ch;
    color: #f5f1ea;
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.75rem;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: rgba(245, 241, 234, 0.68);
    flex-wrap: wrap;
  }

  .post-byline {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.68rem;
  }
  .post-byline em {
    font-style: italic;
    letter-spacing: 0.05em;
    text-transform: none;
    font-size: 0.84rem;
    color: var(--planet-accent, #e2d1c3);
  }

  .post-meta-dot {
    opacity: 0.5;
  }

  .post-date {
    font-style: italic;
    letter-spacing: 0.05em;
    font-size: 0.86rem;
    color: rgba(245, 241, 234, 0.8);
  }

  .post-reading-time {
    font-style: italic;
    letter-spacing: 0.05em;
    font-size: 0.86rem;
    color: rgba(245, 241, 234, 0.8);
  }

  .post-rule,
  .post-footer-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1.75rem auto 0;
    max-width: 18rem;
    color: var(--planet-accent, #e2d1c3);
    opacity: 0.6;
  }
  .post-footer-rule {
    margin: 3rem auto 1rem;
    max-width: 14rem;
  }
  .post-rule::before,
  .post-rule::after,
  .post-footer-rule::before,
  .post-footer-rule::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
  }
  .post-rule-ornament,
  .post-footer-rule span {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
  }

  .post-figure {
    max-width: 44rem;
    margin: 2rem auto 0;
    padding: 0;
  }
  .post-figure :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    filter: grayscale(0.25) saturate(0.9);
  }
  .post-figure figcaption {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-style: italic;
    font-size: 0.8rem;
    color: rgba(245, 241, 234, 0.55);
    text-align: center;
    margin-top: 0.6rem;
    letter-spacing: 0.04em;
  }

  .blog-body-frame {
    position: relative;
    max-width: 44rem;
    margin: 2rem auto 2.5rem;
    padding: 2.5rem clamp(1.5rem, 4vw, 3rem) 2.25rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 2px;
    background: rgba(12, 12, 16, 0.38);
    backdrop-filter: blur(22px) saturate(140%);
    -webkit-backdrop-filter: blur(22px) saturate(140%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -28px rgba(0, 0, 0, 0.6);
    text-align: left;
  }

  .post-reading-shell {
    max-width: 44rem;
    margin: 2rem auto 2.5rem;
  }

  .post-side {
    display: none;
  }

  .post-side-panel {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(12, 12, 16, 0.34);
    backdrop-filter: blur(20px) saturate(130%);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 18px 34px -26px rgba(0, 0, 0, 0.72);
    padding: 1rem 0.95rem;
  }

  .post-side-title {
    margin: 0 0 0.7rem;
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--planet-accent, #e2d1c3);
  }

  :global(html[data-post-theme="texture"]) .post-side-title {
    color: rgba(245, 245, 250, 0.82);
  }

  .post-search-input {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(0, 0, 0, 0.2);
    color: rgba(245, 241, 234, 0.95);
    padding: 0.5rem 0.6rem;
    font-size: 0.88rem;
    margin-bottom: 0.65rem;
    outline: none;
  }

  .post-search-input:focus {
    border-color: rgba(255, 255, 255, 0.5);
  }

  .post-search-results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
    max-height: 48vh;
    overflow: auto;
  }

  .post-search-empty {
    font-size: 0.78rem;
    color: rgba(245, 241, 234, 0.58);
  }

  .post-search-result-btn {
    width: 100%;
    text-align: left;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(245, 241, 234, 0.92);
    padding: 0.35rem 0.45rem;
    font-size: 0.78rem;
    cursor: pointer;
  }

  .post-search-result-btn:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
  }

  .post-outline ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
    max-height: 56vh;
    overflow: auto;
  }

  .post-outline .outline-item a {
    display: block;
    color: rgba(245, 241, 234, 0.78);
    text-decoration: none;
    font-size: 0.8rem;
    line-height: 1.4;
    border-left: 1px solid transparent;
    padding: 0.2rem 0 0.2rem 0.5rem;
  }

  .post-outline .outline-item.depth-3 a {
    padding-left: 1rem;
    font-size: 0.76rem;
    opacity: 0.9;
  }

  .post-outline .outline-item a:hover,
  .post-outline .outline-item a.is-current {
    color: #ffffff;
    border-left-color: var(--planet-accent, #e2d1c3);
  }

  .post-outline-empty {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(245, 241, 234, 0.58);
  }

  .blog-body :global(.post-search-hit) {
    animation: post-hit-fade 1.4s ease;
  }

  @keyframes post-hit-fade {
    0% { background: rgba(255, 255, 255, 0.22); }
    100% { background: transparent; }
  }

  .blog-body-frame::before,
  .blog-body-frame::after {
    content: "";
    position: absolute;
    left: clamp(1.5rem, 4vw, 3rem);
    right: clamp(1.5rem, 4vw, 3rem);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.18),
      transparent
    );
  }
  .blog-body-frame::before {
    top: 0.75rem;
  }
  .blog-body-frame::after {
    bottom: 0.75rem;
  }

  html.light .blog-body-frame {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(0, 0, 0, 0.08);
  }

  /* Paper theme — Venus / Saturn: warm cream backdrop, dark serif body */
  :global(html[data-post-theme="paper"]) .blog-body-frame {
    background: rgba(234, 221, 194, 0.9);
    border-color: rgba(70, 50, 20, 0.18);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 24px 48px -28px rgba(40, 25, 0, 0.25);
  }
  :global(html[data-post-theme="paper"]) .blog-body-frame::before,
  :global(html[data-post-theme="paper"]) .blog-body-frame::after {
    background: linear-gradient(
      to right,
      transparent,
      rgba(70, 50, 20, 0.22),
      transparent
    );
  }
  :global(html[data-post-theme="paper"]) .blog-body {
    color: rgba(45, 35, 22, 0.92);
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(h2) {
    color: #2a1f10;
    border-bottom-color: rgba(70, 50, 20, 0.22);
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(h3) {
    color: #6b5020;
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(blockquote) {
    border-left-color: #b58838;
    color: rgba(65, 50, 25, 0.78);
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(code) {
    background: rgba(70, 50, 20, 0.1);
    color: #3d2a10;
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(pre) {
    background: rgba(70, 50, 20, 0.08);
    border-color: rgba(70, 50, 20, 0.15);
    color: #2d2110;
  }
  :global(html[data-post-theme="paper"]) .blog-body :global(a) {
    color: #8b5a20;
    text-decoration-color: rgba(139, 90, 32, 0.5);
  }

  /* Paper theme — post header, meta, rules, tags */
  :global(html[data-post-theme="paper"]) .post-kicker {
    color: #6b4a18;
    opacity: 0.95;
  }
  :global(html[data-post-theme="paper"]) .post-title {
    color: #1a120a;
    text-shadow: none;
  }
  :global(html[data-post-theme="paper"]) .post-byline {
    color: rgba(60, 45, 20, 0.75);
  }
  :global(html[data-post-theme="paper"]) .post-byline em {
    color: #8b5a20;
  }
  :global(html[data-post-theme="paper"]) .post-meta-dot {
    color: rgba(60, 45, 20, 0.5);
  }
  :global(html[data-post-theme="paper"]) .post-date {
    color: rgba(60, 45, 20, 0.88);
  }
  :global(html[data-post-theme="paper"]) .post-reading-time {
    color: rgba(60, 45, 20, 0.88);
  }
  :global(html[data-post-theme="paper"]) .post-rule,
  :global(html[data-post-theme="paper"]) .post-footer-rule {
    color: #8b5a20;
    opacity: 0.75;
  }
  :global(html[data-post-theme="paper"]) .post-rule::before,
  :global(html[data-post-theme="paper"]) .post-rule::after,
  :global(html[data-post-theme="paper"]) .post-footer-rule::before,
  :global(html[data-post-theme="paper"]) .post-footer-rule::after {
    background: linear-gradient(
      to right,
      transparent,
      rgba(70, 50, 20, 0.3),
      transparent
    );
  }
  :global(html[data-post-theme="paper"]) .post-figure :global(img) {
    border-color: rgba(70, 50, 20, 0.2);
    filter: grayscale(0.2) saturate(0.95);
  }
  :global(html[data-post-theme="paper"]) .post-figure figcaption {
    color: rgba(60, 45, 20, 0.65);
  }
  :global(html[data-post-theme="paper"]) .post-tags-label {
    color: rgba(70, 50, 20, 0.7);
  }

  /* Texture theme — Moon / Mercury: tiled sphere colorMap bg, white body on heavy blur */
  :global(html[data-post-theme="texture"]) .blog-body-frame {
    background: rgba(18, 18, 24, 0.32);
    border-color: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(32px) saturate(125%);
    -webkit-backdrop-filter: blur(32px) saturate(125%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.12) inset,
      0 30px 56px -32px rgba(0, 0, 0, 0.85);
  }
  :global(html[data-post-theme="texture"]) .blog-body-frame::before,
  :global(html[data-post-theme="texture"]) .blog-body-frame::after {
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.28),
      transparent
    );
  }
  :global(html[data-post-theme="texture"]) .blog-body {
    color: rgba(255, 255, 255, 0.96);
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(h2) {
    color: #ffffff;
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(h3) {
    color: rgba(255, 255, 255, 0.92);
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(blockquote) {
    border-left-color: rgba(255, 255, 255, 0.6);
    color: rgba(255, 255, 255, 0.78);
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(code) {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(pre) {
    background: rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.14);
    color: #ffffff;
  }
  :global(html[data-post-theme="texture"]) .blog-body :global(a) {
    color: #ffffff;
    text-decoration-color: rgba(255, 255, 255, 0.55);
  }

  :global(html[data-post-theme="texture"]) .post-kicker {
    color: rgba(255, 255, 255, 0.78);
    opacity: 1;
  }
  :global(html[data-post-theme="texture"]) .post-title {
    color: #ffffff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.45);
  }
  :global(html[data-post-theme="texture"]) .post-byline,
  :global(html[data-post-theme="texture"]) .post-date,
  :global(html[data-post-theme="texture"]) .post-reading-time,
  :global(html[data-post-theme="texture"]) .post-byline em {
