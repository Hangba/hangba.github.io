---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { sortItemsByDateDesc, withBase } from "../utils/helpers";
import PostCardPreview from "../components/PostCardPreview.astro";
import Hero from "../components/Hero.astro";
import HomeEasterEgg from "../components/HomeEasterEgg.astro";
import ArrowRight from "../icons/ArrowRight.astro";

const allPosts = (await getCollection("blogs", ({ data }) => !data.draft)).sort(
    sortItemsByDateDesc
);
---

<MainLayout
    activePage="home"
    pageTitle={siteConfig.title}
>
    <Hero />
    <HomeEasterEgg />

    <section
        id="recent-stories"
        class="recent-stories"
        data-reveal-root
    >
        <h2 class="sigmar-ff section-title" data-reveal style="--reveal-delay:0ms">
            Recent Stories
        </h2>
        <div class="post-list">
            {
                allPosts
                    .slice(0, siteConfig.recentPostLimit)
                    .map((post, i) => (
                        <div
                            class="post-row"
                            data-reveal
                            style={`--reveal-delay:${120 + i * 90}ms`}
                        >
                            <PostCardPreview post={post} />
                        </div>
                    ))
            }
        </div>
        <div data-reveal style={`--reveal-delay:${120 + allPosts.length * 90}ms`}>
            <a
                href={withBase("/blog")}
                class="home-blog-link mt-20"
            >
                Enter the Star Archive
                <ArrowRight class="w-4 h-4 fill-current ml-2 inline" />
            </a>
        </div>
    </section>
</MainLayout>

<style>
    .recent-stories {
        position: relative;
        z-index: 3;
        max-width: 56rem;
        margin: 0 auto;
        padding: 8vh 1.5rem 6vh;
        text-align: center;
    }
    .section-title {
        opacity: 0.85;
        font-size: 1.75rem;
        text-align: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
    }
    .post-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: center;
    }
    .post-row {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .home-blog-link {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-serif, "New Computer Modern Roman", serif);
        font-size: 0.96rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #ffffff !important;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.28);
        padding: 0.2rem 0;
        transition:
            color 220ms ease,
            transform 220ms ease,
            border-color 220ms ease,
            opacity 220ms ease;
    }

    .home-blog-link:hover,
    .home-blog-link:focus-visible {
        transform: translateY(-1px);
        color: rgba(255, 255, 255, 0.98) !important;
        border-color: rgba(255, 255, 255, 0.62);
        opacity: 1;
    }

    .home-blog-link :global(svg) {
        transition: transform 220ms ease;
    }

    .home-blog-link:hover :global(svg),
    .home-blog-link:focus-visible :global(svg) {
        transform: translateX(2px);
    }

    :global(html[data-post-theme="paper"]) .home-blog-link {
        color: #ffffff !important;
        border-color: rgba(70, 50, 20, 0.35);
    }

    :global(html[data-post-theme="paper"]) .home-blog-link:hover,
    :global(html[data-post-theme="paper"]) .home-blog-link:focus-visible {
        color: #ffffff !important;
        border-color: rgba(139, 90, 32, 0.58);
    }

    :global(html[data-post-theme="texture"]) .home-blog-link {
        color: #ffffff !important;
        border-color: rgba(255, 255, 255, 0.32);
    }

    :global(html[data-post-theme="texture"]) .home-blog-link:hover,
    :global(html[data-post-theme="texture"]) .home-blog-link:focus-visible {
        color: rgba(245, 241, 234, 0.98) !important;
        border-color: rgba(255, 255, 255, 0.42);
    }
</style>
