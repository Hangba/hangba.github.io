---
import {
  getAllTags,
  getPostsByTag,
  sortItemsByDateDesc,
  withBase,
} from "../../utils/helpers";
import { getCollection } from "astro:content";
import Button from "../../components/Button.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";

const posts = (await getCollection("blogs")).sort(sortItemsByDateDesc);
const tags = getAllTags(posts).sort((tagA, tagB) => {
  const postCountTagA = getPostsByTag(posts, tagA.id).length;
  const postCountTagB = getPostsByTag(posts, tagB.id).length;
  return postCountTagB - postCountTagA;
});
---

<MainLayout
  activePage="tags"
  pageTitle={siteConfig.title + " | " + "Tags Index"}
>
  <div class="page-content landing-content" data-reveal-root>
    <h1 class="sigmar-ff text-balance" data-reveal style="--reveal-delay:0ms">Tags</h1>
    <p class="kanit-regular" data-reveal style="--reveal-delay:120ms">Select a tag to view related posts.</p>
    <div class="flex flex-wrap items-center justify-center gap-4" data-reveal style="--reveal-delay:240ms">
      {
        tags.map((tag) => {
          const postCount = getPostsByTag(posts, tag.id).length;
          return (
            <Button href={`${withBase("/tags/" + tag.id)}`} class="px-4! m-2">
              {tag.name} ({postCount})
            </Button>
          );
        })
      }
    </div>
  </div>
</MainLayout>

<style>
  .landing-content {
    position: relative;
    z-index: 3;
  }
</style>
