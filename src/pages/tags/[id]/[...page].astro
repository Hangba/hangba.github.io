---
import { getCollection } from "astro:content";
import {
  getAllTags,
  getPostsByTag,
  sortItemsByDateDesc,
} from "../../../utils/helpers";
import type { GetStaticPathsOptions, Page } from "astro";
import siteConfig from "../../../site.config";
import type { CollectionEntry } from "astro:content";
import MainLayout from "../../../layouts/MainLayout.astro";
import Pagination from "../../../components/Pagination.astro";
import PostListPreview from "../../../components/PostListPreview.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getCollection("blogs", ({ data }) => !data.draft)).sort(
    sortItemsByDateDesc
  );
  const tags = getAllTags(posts);

  return tags.flatMap((tag) => {
    const filteredPosts = getPostsByTag(posts, tag.id);
    return paginate(filteredPosts, {
      params: { id: tag.id },
      pageSize: siteConfig.postsPerPage || 2,
    });
  });
}

type Props = { page: Page<CollectionEntry<"blogs">> };

const { page } = Astro.props;
const blog = page.data;
const params = Astro.params;
const allPosts = await getCollection("blogs", (post) =>
  !post.data.draft && post.data.tags?.includes(params.id)
);
const allTags = getAllTags(allPosts);
const currentTag = allTags.find((tag) => {
  return tag.id === params.id;
});
---

<MainLayout activePage="tags" pageTitle={siteConfig.title + "| " + currentTag?.name + " posts"}>
  <div class="page-content landing-content magazine-wrap" data-reveal-root>
    <div class="magazine-header" data-reveal style="--reveal-delay:80ms">
      <span class="magazine-kicker">The Journal &mdash; Tag</span>
      <h1 class="magazine-masthead">{currentTag?.name}</h1>
      <p class="magazine-dek">Posts filed under <em>{currentTag?.name}</em>.</p>
      <div class="magazine-rule" aria-hidden="true">
        <span class="magazine-rule-ornament">&#10070;</span>
      </div>
    </div>

    <div class="magazine-frame text-left" data-reveal style="--reveal-delay:80ms">
      <div class="flex flex-col gap-8">
        {blog.map((post) => <PostListPreview post={post} />)}
      </div>
    </div>

    <div data-reveal style="--reveal-delay:200ms">
      <Pagination page={page} class="mb-16 sm:mb-24" />
    </div>
  </div>
</MainLayout>

<style>
  .magazine-wrap {
    position: relative;
    z-index: 3;
  }

  .magazine-header {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .magazine-kicker {
    display: inline-block;
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-size: 0.72rem;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--planet-accent, #e2d1c3);
    margin-bottom: 1.25rem;
    opacity: 0.9;
  }

  .magazine-masthead {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-weight: 300;
    font-size: clamp(3rem, 7vw, 5.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 1rem;
    color: #f5f1ea;
  }

  .magazine-dek {
    font-family: var(--font-serif, "New Computer Modern Roman", serif);
    font-style: italic;
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 38ch;
    margin: 0 auto 1.75rem;
    color: rgba(245, 241, 234, 0.72);
    line-height: 1.6;
  }

  .magazine-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1rem auto 0;
    max-width: 20rem;
    color: var(--planet-accent, #e2d1c3);
    opacity: 0.65;
  }
  .magazine-rule::before,
  .magazine-rule::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
  }
  .magazine-rule-ornament {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
  }

  .magazine-frame {
    position: relative;
    max-width: 44rem;
    margin: 2rem auto 2.5rem;
    padding: 2.5rem clamp(1.5rem, 4vw, 3rem);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 2px;
    background: rgba(12, 12, 16, 0.38);
    backdrop-filter: blur(22px) saturate(140%);
    -webkit-backdrop-filter: blur(22px) saturate(140%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -28px rgba(0, 0, 0, 0.6);
  }
  .magazine-frame::before,
  .magazine-frame::after {
    content: "";
    position: absolute;
    left: clamp(1.5rem, 4vw, 3rem);
    right: clamp(1.5rem, 4vw, 3rem);
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.18), transparent);
  }
  .magazine-frame::before { top: 0.75rem; }
  .magazine-frame::after  { bottom: 0.75rem; }

  /* Paper theme */
  :global(html[data-post-theme="paper"]) .magazine-kicker { color: #6b4a18; opacity: 1; }
  :global(html[data-post-theme="paper"]) .magazine-masthead { color: #1a120a; }
  :global(html[data-post-theme="paper"]) .magazine-dek { color: rgba(50, 35, 15, 0.78); }
  :global(html[data-post-theme="paper"]) .magazine-rule { color: #8b5a20; opacity: 0.8; }
  :global(html[data-post-theme="paper"]) .magazine-rule::before,
  :global(html[data-post-theme="paper"]) .magazine-rule::after {
    background: linear-gradient(to right, transparent, rgba(70,50,20,0.3), transparent);
  }
  :global(html[data-post-theme="paper"]) .magazine-frame {
    background: rgba(234, 221, 194, 0.9);
    border-color: rgba(70, 50, 20, 0.18);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 24px 48px -28px rgba(40, 25, 0, 0.25);
  }
  :global(html[data-post-theme="paper"]) .magazine-frame::before,
  :global(html[data-post-theme="paper"]) .magazine-frame::after {
    background: linear-gradient(to right, transparent, rgba(70,50,20,0.22), transparent);
  }

  /* Slate theme */
  :global(html[data-post-theme="texture"]) .magazine-kicker { color: rgba(255,255,255,0.78); opacity: 1; }
  :global(html[data-post-theme="texture"]) .magazine-masthead { color: #ffffff; }
  :global(html[data-post-theme="texture"]) .magazine-dek { color: rgba(255,255,255,0.78); }
  :global(html[data-post-theme="texture"]) .magazine-rule { color: rgba(255,255,255,0.72); opacity: 1; }
  :global(html[data-post-theme="texture"]) .magazine-rule::before,
  :global(html[data-post-theme="texture"]) .magazine-rule::after {
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.35), transparent);
  }
  :global(html[data-post-theme="texture"]) .magazine-frame {
    background: rgba(18, 18, 24, 0.45);
    border-color: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(32px) saturate(125%);
    -webkit-backdrop-filter: blur(32px) saturate(125%);
  }
  :global(html[data-post-theme="texture"]) .magazine-frame::before,
  :global(html[data-post-theme="texture"]) .magazine-frame::after {
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.28), transparent);
  }
</style>
